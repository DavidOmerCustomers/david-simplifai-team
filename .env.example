APP_SLUG=david
# Development example. Use an environment-specific file for QAS/PRD when adapters differ.
CM_ENV=dev
RUNTIME_ADAPTER_CODE=static-github

# ------------------------------
# anything below this line probably should not be edited manually
# ------------------------------
STACK="${APP_SLUG}${CM_ENV:+-${CM_ENV}}"
LOCAL_DOMAIN=localtest.me
APP_HOST="${STACK}.${LOCAL_DOMAIN}"

URI_SCHEME=http:
SITE_URL="${URI_SCHEME}//${APP_HOST}"

# Browser-safe analytics values. Leave blank in dev unless analytics testing is intentional.
GTM_CONTAINER_ID=
GA4_MEASUREMENT_ID=
ANALYTICS_NOTES="The site installs Google Tag Manager only. GA4/Google Tag should be configured inside the GTM container to avoid duplicate page_view events."

# ------------------------------
# Et al Solutions – EPC Tag Contract
# ------------------------------
OWNER=omer
OWNER_ALIAS=etalsolutions
MANAGED_BY=github-pages
LIFECYCLE=long-lived
DATA_CLASS=public
DATA_LIFECYCLE=persistent
