APP_SLUG=david
CM_ENV= #empty for production, or staging, dev, etc. for non-production environments
RUNTIME_ADAPTER_CODE=pages-github

# ------------------------------
# anything below this line probably shouldn't be edited manually
# ------------------------------
STACK="${APP_SLUG}${CM_ENV:+-${CM_ENV}}"
LOCAL_DOMAIN=simplifai.team
APP_HOST=$STACK.$LOCAL_DOMAIN

URI_SCHEME=https:
SITE_URL=$URI_SCHEME//$APP_HOST

GTM_CONTAINER_ID=GTM-PJFK7G8X
GA4_MEASUREMENT_ID=G-6W6PYL2FP0


  "site": "david.simplifai.team",
  "gtmContainerId": "GTM-PJFK7G8X",
  "ga4MeasurementId": "G-6W6PYL2FP0",
  "notes": "The site installs Google Tag Manager only. GA4/Google Tag should be configured inside the GTM container to avoid duplicate page_view events."


# ------------------------------
# Et al Solutions – EPC Tag Contract
# ------------------------------

OWNER=omer
# Ownership (logical, not personal)
OWNER_ALIAS=etalsolutions             # Allowed: etalsolutions | client-it | client-dev | vendor | other

# Control plane
MANAGED_BY=compose              # Allowed: compose | k8s | terraform | manual | other

# Container lifecycle
LIFECYCLE=long-lived                  # Allowed: ephemeral | long-lived | job

# Data governance
DATA_CLASS=confidential               # Allowed: public | internal | confidential | regulated
DATA_LIFECYCLE=persistent             # Allowed: transient | persistent | archival
